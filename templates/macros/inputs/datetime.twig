{% macro datetime(attributes) %}
  {% set rand = random() %}
  {% set input_id = attributes.id|default(rand) %}
  {% set hidden_id = 'hidden_' ~ input_id %}
  <input class='form-control' step="1" {% if not attributes.id %} id="{{ input_id }}" {% endif %}
    {% for name, value in attributes|filter((v, k) => k != 'name') %} {{name}}="{{value|replace({' ': 'T'})}}" {% endfor %}
      aria-label="{{ attributes.name }}"/>
  <input type="hidden" id="{{ hidden_id }}" name="{{ attributes.name }}" value="{{ attributes.value|replace({'T': ' '}) }}" {{attributes.disabled ? 'disabled' : ''}}>
  <script>
    (() => {
      const visibleInput = document.getElementById('{{ input_id }}');
      const hiddenInput = document.getElementById('{{ hidden_id }}');

      if (!visibleInput || !hiddenInput) {
        return;
      }

      const normalizeDateTimeValue = (value) => {
        if (!value) {
          return '';
        }

        const normalized = value.replace('T', ' ');
        return normalized.length === 16 ? normalized + ':00' : normalized;
      };

      const syncHiddenInput = () => {
        const normalizedValue = normalizeDateTimeValue(visibleInput.value);
        hiddenInput.value = normalizedValue;
        hiddenInput.disabled = visibleInput.disabled || normalizedValue === '';
      };

      syncHiddenInput();
      visibleInput.addEventListener('change', syncHiddenInput);
      visibleInput.addEventListener('input', syncHiddenInput);
    })();
  </script>
{% endmacro %}
{{ _self.datetime(attributes) }}
